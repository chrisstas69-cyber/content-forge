// Dog Content Automation System - Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Video {
  id             String   @id @default(cuid())
  filename       String
  originalPath   String
  processedPath  String?  // primary processed file (16:9 horizontal by default)
  processedFormats String? // JSON: { "16:9": "/path", "9:16": "/path", "1:1": "/path" }
  thumbnailPath  String?
  thumbnailFormats String? // JSON: { "16:9": "/path", "9:16": "/path", "1:1": "/path" }
  sizeBytes      Int
  durationSec    Float?
  width          Int?
  height         Int?
  mimeType       String

  // AI analysis
  transcription  String?
  viralScore     Int?
  aiCaption      String?
  aiHashtags     String?
  aiTitle        String?
  aiDescription  String?

  // Voiceover
  voiceoverText  String?  // AI-generated script
  voiceoverVoice String?  // voice ID used
  voiceoverPath  String?  // path to generated audio
  voiceoverEnabled Boolean @default(false)

  // Subtitle translation
  translations  String?  // JSON: { "es": "translated text", "fr": "...", ... }

  // Repurposing — clips reference their parent video
  parentId      String?  // if this video is a clip, the parent video ID
  parent        Video?   @relation("VideoClips", fields: [parentId], references: [id], onDelete: Cascade)
  clips         Video[]  @relation("VideoClips")
  isClip        Boolean  @default(false)
  clipStart     Float?   // start time in parent (seconds)
  clipEnd       Float?   // end time in parent (seconds)

  // Status: pending | transcribing | editing | scoring | ready | publishing | published | failed
  status         String   @default("pending")
  progress       Int      @default(0)
  currentStep    String?
  errorMessage   String?

  // Editing settings snapshot (JSON)
  editSettings   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobs           Job[]
  posts          Post[]
  analytics      AnalyticsCache[]
}

model Job {
  id           String   @id @default(cuid())
  videoId      String
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  type         String   // transcribe | edit | score | publish
  status       String   @default("queued") // queued | running | completed | failed
  progress     Int      @default(0)
  message      String?
  result       String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SocialAccount {
  id           String   @id @default(cuid())
  platform     String   // youtube | tiktok | instagram | facebook | x
  handle       String
  displayName  String?
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  metadata     String?  // platform-specific JSON
  connected    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]
}

model Post {
  id           String   @id @default(cuid())
  videoId      String
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  accountId    String
  account      SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform     String
  status       String   @default("pending") // pending | uploading | published | failed | scheduled
  platformPostId String?
  platformUrl  String?
  title        String?
  description  String?
  hashtags     String?
  errorMessage String?
  scheduledAt  DateTime? // When to publish (null = publish immediately)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  analytics    AnalyticsCache[]
}

model Setting {
  id    String @id
  value String
}

/// Encrypted app secrets (API keys, client secrets, etc.)
/// Encrypted with AES-256-GCM using ENCRYPTION_KEY env var.
model AppSecret {
  id           String   @id // e.g. "youtube.client_id", "meta.app_secret"
  label        String   // human-friendly name
  platform     String   // youtube | tiktok | meta | x | other
  cipherText   String   // base64 iv + ciphertext + tag
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Asset {
  id        String   @id @default(cuid())
  type      String   // watermark | intro | outro | music | font
  name      String
  filePath  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())
}

/// Trending hashtags, sounds, formats scraped from web search
model Trend {
  id         String   @id @default(cuid())
  platform   String   // tiktok | instagram | youtube | x | reddit | general
  type       String   // hashtag | sound | format | topic
  content    String   // the hashtag/sound name or topic description
  niche      String   // niche context (e.g. "dog / pet content")
  summary    String?  // short description of why it's trending
  sourceUrl  String?
  score      Int      @default(0) // relevance score 0-100
  freshness  DateTime @default(now()) // when this trend was discovered
  createdAt  DateTime @default(now())
  @@index([platform, niche])
  @@index([freshness])
}

/// Cached analytics metrics per post (refreshed periodically)
model AnalyticsCache {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  platform   String
  metrics    String   // JSON: { views, likes, comments, shares, saves, reach, impressions }
  fetchedAt  DateTime @default(now())
  @@index([videoId])
  @@index([fetchedAt])
}

/// AI Agent conversation history
model AgentConversation {
  id         String   @id @default(cuid())
  title      String   @default("New conversation")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  messages   AgentMessage[]
}

model AgentMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // user | assistant | tool
  content        String
  toolCalls      String?  // JSON array of tool calls (for assistant)
  toolCallId     String?  // for role=tool, the tool call this responds to
  toolName       String?  // for role=tool, which tool was called
  createdAt      DateTime @default(now())
  @@index([conversationId])
}

/// AI-generated content ideas
model Idea {
  id              String   @id @default(cuid())
  title           String
  concept         String   // 1-2 sentence description
  scriptOutline   String?  // bullet-point script outline
  format          String   // 9:16 | 16:9 | 1:1 | carousel
  predictedViralScore Int  @default(50)
  source          String   // trends | insights | analytics | manual | competitor
  sourceData      String?  // JSON: what trends/insights informed this idea
  niche           String
  status          String   @default("new") // new | generating | generated | used | rejected
  generatedVideoId String? // if used to generate a video
  createdAt       DateTime @default(now())
  @@index([niche, status])
  @@index([createdAt])
}

/// AI-generated assets (B-roll, thumbnails, images)
model GeneratedAsset {
  id           String   @id @default(cuid())
  type         String   // broll | thumbnail | image | stylized_video
  prompt       String
  filePath     String?  // local path if downloaded
  publicUrl    String?  // public URL (from Replicate)
  thumbnailUrl String?  // for videos
  modelUsed    String   // which AI model was used
  status       String   @default("pending") // pending | generating | ready | failed
  errorMessage String?
  metadata     String?  // JSON: model-specific data
  videoId      String?  // if associated with a video (thumbnail)
  createdAt    DateTime @default(now())
  @@index([type, status])
}

/// Insights from analytics (learning loop)
model Insight {
  id         String   @id @default(cuid())
  type       String   // pattern | opportunity | underperformer | recommendation
  content    String   // the insight text
  data       String   // JSON: supporting metrics
  niche      String
  confidence Int      @default(50) // 0-100
  freshness  DateTime @default(now())
  createdAt  DateTime @default(now())
  @@index([niche, type])
  @@index([freshness])
}

/// Brand Kit — logo, colors, fonts stored once, auto-applied to every video
model BrandKit {
  id           String   @id @default("default")
  brandName    String?
  logoPath     String?
  primaryColor String?  // hex like #FF6B35
  secondaryColor String?
  accentColor  String?
  fontFamily   String?
  watermarkPosition String? // top-left | top-right | bottom-left | bottom-right | center
  watermarkOpacity Float?
  watermarkScale Float?
  updatedAt    DateTime @updatedAt
}

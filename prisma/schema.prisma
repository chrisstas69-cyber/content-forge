// Dog Content Automation System - Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Video {
  id             String   @id @default(cuid())
  filename       String
  originalPath   String
  processedPath  String?  // primary processed file (16:9 horizontal by default)
  processedFormats String? // JSON: { "16:9": "/path", "9:16": "/path", "1:1": "/path" }
  thumbnailPath  String?
  thumbnailFormats String? // JSON: { "16:9": "/path", "9:16": "/path", "1:1": "/path" }
  sizeBytes      Int
  durationSec    Float?
  width          Int?
  height         Int?
  mimeType       String

  // AI analysis
  transcription  String?
  viralScore     Int?
  aiCaption      String?
  aiHashtags     String?
  aiTitle        String?
  aiDescription  String?

  // Voiceover
  voiceoverText  String?  // AI-generated script
  voiceoverVoice String?  // voice ID used
  voiceoverPath  String?  // path to generated audio
  voiceoverEnabled Boolean @default(false)

  // Subtitle translation
  translations  String?  // JSON: { "es": "translated text", "fr": "...", ... }

  // Repurposing — clips reference their parent video
  parentId      String?  // if this video is a clip, the parent video ID
  parent        Video?   @relation("VideoClips", fields: [parentId], references: [id], onDelete: Cascade)
  clips         Video[]  @relation("VideoClips")
  isClip        Boolean  @default(false)
  clipStart     Float?   // start time in parent (seconds)
  clipEnd       Float?   // end time in parent (seconds)

  // Status: pending | transcribing | editing | scoring | ready | publishing | published | failed
  status         String   @default("pending")
  progress       Int      @default(0)
  currentStep    String?
  errorMessage   String?

  // Editing settings snapshot (JSON)
  editSettings   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobs           Job[]
  posts          Post[]
  analytics      AnalyticsCache[]
  hookVariants   HookVariant[]
}

model Job {
  id           String   @id @default(cuid())
  videoId      String
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  type         String   // transcribe | edit | score | publish
  status       String   @default("queued") // queued | running | completed | failed
  progress     Int      @default(0)
  message      String?
  result       String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SocialAccount {
  id           String   @id @default(cuid())
  platform     String   // youtube | tiktok | instagram | facebook | x
  handle       String
  displayName  String?
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  metadata     String?  // platform-specific JSON
  connected    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]
}

model Post {
  id           String   @id @default(cuid())
  videoId      String
  video        Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  accountId    String
  account      SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform     String
  status       String   @default("pending") // pending | uploading | published | failed | scheduled
  platformPostId String?
  platformUrl  String?
  title        String?
  description  String?
  hashtags     String?
  errorMessage String?
  scheduledAt  DateTime? // When to publish (null = publish immediately)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  analytics    AnalyticsCache[]
  comments     Comment[]
}

model Setting {
  id    String @id
  value String
}

/// Encrypted app secrets (API keys, client secrets, etc.)
/// Encrypted with AES-256-GCM using ENCRYPTION_KEY env var.
model AppSecret {
  id           String   @id // e.g. "youtube.client_id", "meta.app_secret"
  label        String   // human-friendly name
  platform     String   // youtube | tiktok | meta | x | other
  cipherText   String   // base64 iv + ciphertext + tag
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Asset {
  id        String   @id @default(cuid())
  type      String   // watermark | intro | outro | music | font
  name      String
  filePath  String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())
}

/// Trending hashtags, sounds, formats scraped from web search
model Trend {
  id         String   @id @default(cuid())
  platform   String   // tiktok | instagram | youtube | x | reddit | general
  type       String   // hashtag | sound | format | topic
  content    String   // the hashtag/sound name or topic description
  niche      String   // niche context (e.g. "dog / pet content")
  summary    String?  // short description of why it's trending
  sourceUrl  String?
  score      Int      @default(0) // relevance score 0-100
  freshness  DateTime @default(now()) // when this trend was discovered
  createdAt  DateTime @default(now())
  @@index([platform, niche])
  @@index([freshness])
}

/// Cached analytics metrics per post (refreshed periodically)
model AnalyticsCache {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  videoId    String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  platform   String
  metrics    String   // JSON: { views, likes, comments, shares, saves, reach, impressions }
  fetchedAt  DateTime @default(now())
  @@index([videoId])
  @@index([fetchedAt])
}

/// AI Agent conversation history
model AgentConversation {
  id         String   @id @default(cuid())
  title      String   @default("New conversation")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  messages   AgentMessage[]
}

model AgentMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String   // user | assistant | tool
  content        String
  toolCalls      String?  // JSON array of tool calls (for assistant)
  toolCallId     String?  // for role=tool, the tool call this responds to
  toolName       String?  // for role=tool, which tool was called
  createdAt      DateTime @default(now())
  @@index([conversationId])
}

/// AI-generated content ideas
model Idea {
  id              String   @id @default(cuid())
  title           String
  concept         String   // 1-2 sentence description
  scriptOutline   String?  // bullet-point script outline
  format          String   // 9:16 | 16:9 | 1:1 | carousel
  predictedViralScore Int  @default(50)
  source          String   // trends | insights | analytics | manual | competitor
  sourceData      String?  // JSON: what trends/insights informed this idea
  niche           String
  status          String   @default("new") // new | generating | generated | used | rejected
  generatedVideoId String? // if used to generate a video
  createdAt       DateTime @default(now())
  @@index([niche, status])
  @@index([createdAt])
}

/// AI-generated assets (B-roll, thumbnails, images)
model GeneratedAsset {
  id           String   @id @default(cuid())
  type         String   // broll | thumbnail | image | stylized_video
  prompt       String
  filePath     String?  // local path if downloaded
  publicUrl    String?  // public URL (from Replicate)
  thumbnailUrl String?  // for videos
  modelUsed    String   // which AI model was used
  status       String   @default("pending") // pending | generating | ready | failed
  errorMessage String?
  metadata     String?  // JSON: model-specific data
  videoId      String?  // if associated with a video (thumbnail)
  createdAt    DateTime @default(now())
  @@index([type, status])
}

/// Insights from analytics (learning loop)
model Insight {
  id         String   @id @default(cuid())
  type       String   // pattern | opportunity | underperformer | recommendation
  content    String   // the insight text
  data       String   // JSON: supporting metrics
  niche      String
  confidence Int      @default(50) // 0-100
  freshness  DateTime @default(now())
  createdAt  DateTime @default(now())
  @@index([niche, type])
  @@index([freshness])
}

/// Brand Kit — logo, colors, fonts stored once, auto-applied to every video
model BrandKit {
  id           String   @id @default("default")
  brandName    String?
  logoPath     String?
  primaryColor String?  // hex like #FF6B35
  secondaryColor String?
  accentColor  String?
  fontFamily   String?
  watermarkPosition String? // top-left | top-right | bottom-left | bottom-right | center
  watermarkOpacity Float?
  watermarkScale Float?
  updatedAt    DateTime @updatedAt
}

/// Voice Profile — defines the user's persona for AI-generated replies + scripts
model VoiceProfile {
  id              String   @id @default("default")
  persona         String   // e.g. "friendly dog mom who loves puns"
  tone            String   // e.g. "warm, witty, enthusiastic"
  signaturePhrases String? // e.g. "pawsome, fur-real, zoomies"
  avoidPhrases    String?  // phrases to never use
  autoReplyMode   String   @default("suggest") // suggest | auto
  replyLength     String   @default("short") // short | medium | long
  updatedAt       DateTime @updatedAt
}

/// Comments fetched from social platforms — for auto-reply
model Comment {
  id              String   @id @default(cuid())
  postId          String
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  platformCommentId String
  platform        String
  authorName      String
  authorHandle    String?
  text            String
  replyStatus     String   @default("pending") // pending | replied | ignored | failed
  replyText       String?
  replyError      String?
  repliedAt       DateTime?
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  @@unique([postId, platformCommentId])
  @@index([replyStatus])
}

/// Hook A/B variants — opening text overlays for testing
model HookVariant {
  id              String   @id @default(cuid())
  videoId         String
  video           Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  hookText        String   // the opening 3-second text overlay
  hookStyle       String   // question | bold-claim | curiosity | stat | story
  postId          String?  // if used in a published post
  performance     String?  // JSON: { views, likes, comments } at 24h
  isWinner        Boolean  @default(false)
  createdAt       DateTime @default(now())
  @@index([videoId])
}

/// Competitor accounts being monitored
model Competitor {
  id           String   @id @default(cuid())
  platform     String   // youtube | tiktok | instagram | facebook | x
  handle       String
  displayName  String?
  lastChecked  DateTime?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  posts        CompetitorPost[]
  @@unique([platform, handle])
}

/// Posts from monitored competitors
model CompetitorPost {
  id              String   @id @default(cuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  platformPostId  String
  platform        String
  title           String?
  description     String?
  url             String
  metrics         String?  // JSON: { views, likes, comments, shares }
  viralScore      Int?     // our AI's estimate
  suggestedAction String?  // AI's suggestion for how to respond
  alertSent       Boolean  @default(false)
  postedAt        DateTime?
  fetchedAt       DateTime @default(now())
  @@unique([competitorId, platformPostId])
  @@index([alertSent])
}

/// Analyzed viral scripts — reverse-engineered from any video URL
model AnalyzedScript {
  id              String   @id @default(cuid())
  url             String   // original video URL
  platform        String   // youtube | tiktok | instagram
  title           String?
  thumbnailUrl    String?
  hookText        String?  // 0-3 second opening text
  patternInterrupt String? // what breaks the scroll
  bodyText        String?  // main content
  ctaText         String?  // call to action
  fullScript      String?  // complete transcript
  psychologyTriggers String? // JSON: ["urgency", "scarcity", "social_proof", ...]
  framework       String?  // JSON: { steps: ["hook", "agitation", "solution", "proof", "cta"] }
  viralScore      Int?     // 0-100
  analysisNotes   String?  // AI's explanation of why it works
  adaptedScript   String?  // user's adapted version for their niche
  sourceType      String   @default("single") // single | bulk | auto
  createdAt       DateTime @default(now())
  @@index([platform, createdAt])
  @@index([viralScore])
}

/// Reusable framework templates extracted from viral videos
model Framework {
  id           String   @id @default(cuid())
  name         String   // e.g. "Problem-Agitation-Solution-Proof-CTA"
  description  String
  steps        String   // JSON: ["Hook (0-3s)", "Pattern Interrupt", "Body", "CTA"]
  psychologyTriggers String?
  exampleScript String?
  sourceUrl    String?
  niche        String?
  useCount     Int      @default(0)
  createdAt    DateTime @default(now())
  @@index([niche])
}
